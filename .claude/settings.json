{
  "permissions": {
    "allow": [
      "Bash(cabal build*)",
      "Bash(cabal test*)",
      "Bash(cabal run*)",
      "Bash(cabal repl*)",
      "Bash(cabal clean*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(curl*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(mkdir*)",
      "Bash(ls*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git reset*)",
      "Bash(git rebase*)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/norihito.nakata/personal/haskell/auction-service && cabal build 2>&1 | tail -5"
          }
        ]
      }
    ]
  }
}
